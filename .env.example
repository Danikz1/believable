# === Required (Stage 1+) ===
DATABASE_URL=postgresql://bm:bm_dev_password@localhost:5432/believable_minds

# === Stage 2: YouTube Discovery ===
# YOUTUBE_API_KEY=

# === Stage 3: Transcription ===
# DEEPGRAM_API_KEY=
# TRANSCRIPTION_PROVIDER=deepgram  # 'deepgram' (default) or 'whisperx'

# === Stage 4+: LLM Enrichment ===
# QWEN_API_KEY=
# QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  # or dashscope-us / dashscope (Beijing)
# LLM_PROVIDER=qwen  # 'qwen' (default), 'anthropic', or 'openai'
# OPENAI_MODEL=gpt-5.2
# ANTHROPIC_MODEL=claude-sonnet-4-6
# QWEN_MODEL=qwen3.5-plus  # hybrid thinking enabled by default

# === Stage 5: Embeddings ===
# OPENAI_API_KEY=
# EMBEDDING_DIMENSIONS=1536

# === Stage 6: Mukhtar.AI Integration ===
# ANTHROPIC_API_KEY=
# ADMIN_API_KEY=bm-admin-key

# === YouTube Proxy (for cloud deploys) ===
# YOUTUBE_PROXY=socks5://user:pass@proxy:1080  # or http://proxy:8080

# === Database Connection Pooling ===
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=1800
# DB_POOL_PRE_PING=true

# === Stage 8: Brief Delivery ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_TO=
# EMAIL_FROM=
# EMAIL_TO=
